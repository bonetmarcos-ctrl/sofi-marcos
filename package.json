{
  "name": "sofi-marqui-monorepo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "npm run build -w @sofi-marqui/domain && concurrently -n api,web -c blue,magenta \"npm run dev -w @sofi-marqui/api\" \"npm run dev -w @sofi-marqui/web\"",
    "dev:api": "npm run dev -w @sofi-marqui/api",
    "dev:web": "npm run dev -w @sofi-marqui/web",
    "build": "npm run build -w @sofi-marqui/domain && npm run build -w @sofi-marqui/web && npm run build -w @sofi-marqui/api",
    "test": "npm run build -w @sofi-marqui/domain && npm run test --workspaces --if-present",
    "lint": "eslint .",
    "format": "prettier --write .",
    "check": "npm run lint && npm run test && npm run build",
    "start": "npm run start -w @sofi-marqui/api"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "concurrently": "^9.2.0",
    "eslint": "^9.29.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^15.15.0",
    "prettier": "^3.5.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
