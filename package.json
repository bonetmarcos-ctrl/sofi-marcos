{
  "name": "sofi-marqui-monorepo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"npm run dev -w @sofi-marqui/api\" \"npm run dev -w @sofi-marqui/web\"",
    "dev:api": "npm run dev -w @sofi-marqui/api",
    "dev:web": "npm run dev -w @sofi-marqui/web",
    "build": "npm run build -w @sofi-marqui/domain && npm run build -w @sofi-marqui/web && npm run build -w @sofi-marqui/api",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint .",
    "format": "prettier --write .",
    "check": "npm run lint && npm run test && npm run build",
    "start": "npm run start -w @sofi-marqui/api"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "concurrently": "^9.2.0",
    "eslint": "^9.29.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^15.15.0",
    "prettier": "^3.5.3"
  }
}
